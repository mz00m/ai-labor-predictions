{
  "name": "ai-labor-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "digest": "tsx scripts/generate-digest.ts",
    "digest:14": "tsx scripts/generate-digest.ts --days 14",
    "digest:fetch": "tsx scripts/fetch-sources.ts",
    "digest:synthesize": "tsx scripts/synthesize-digest.ts",
    "digest:pipeline": "tsx scripts/fetch-sources.ts && tsx scripts/synthesize-digest.ts",
    "digest:dry-run": "tsx scripts/fetch-sources.ts && tsx scripts/synthesize-digest.ts --dry-run",
    "ingest": "tsx scripts/ingest-source.ts",
    "ingest:from-digest": "tsx scripts/ingest-from-digest.ts",
    "ingest:apply": "tsx scripts/apply-ingestion.ts",
    "signals:fetch": "python3 scripts/signals/fetch_all.py",
    "signals:calc": "python3 scripts/signals/calculate_metrics.py",
    "signals:update": "python3 scripts/signals/fetch_all.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@vercel/analytics": "^1.6.1",
    "date-fns": "^3.6.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
